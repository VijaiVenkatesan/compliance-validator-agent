# # Compliance Validator Agent - Environment Variables

# LLM Provider: groq | gemini | mock
LLM_PROVIDER=gemini

# API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mock API (Optional - Safe to enable)
USE_MOCK_API=true
MOCK_API_URL=http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/compliance_validator.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Processing
PROCESSING_DATE=2026-05-06
CONFIDENCE_THRESHOLD=0.7

# LLM Settings
LLM_TEMPERATURE=0.05
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2

# Optional: Gemini fallback config
GEMINI_MODEL=gemini-2.5-flash